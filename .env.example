# =============================================================================
# Hermes Squad — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# The .gitignore file already excludes it.
# =============================================================================

# =============================================================================
# AI Provider API Keys
# =============================================================================
# At least one key is required for the corresponding agent to work.
# Keys are passed securely to agent subprocesses.

# Anthropic (Claude Code, Claude Chat)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI (Codex CLI, GPT-based agents)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Google AI (Gemini CLI)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your-google-ai-key-here

# AWS Bedrock (for Amazon Q, Claude via Bedrock)
# Uses AWS credential chain — set these OR use ~/.aws/credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# Application Configuration
# =============================================================================

# Application mode: "electron" | "tui" | "server" | "daemon"
# - electron: Full GUI mode (default for desktop)
# - tui: Terminal UI mode (like Claude Squad)
# - server: HTTP API server (for integrations)
# - daemon: Background service (auto-start agents)
HERMES_MODE=tui

# Log level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# Log format: "pretty" (human-readable) | "json" (structured, for production)
LOG_FORMAT=pretty

# Data directory for persistent state, sessions, and memory
# Default: ~/.hermes-squad/data
HERMES_DATA_DIR=

# =============================================================================
# Server Configuration (for server/daemon mode)
# =============================================================================

# HTTP API port
HERMES_PORT=3847

# ACP (Agent Communication Protocol) server port
ACP_PORT=3848

# Authentication token for API access (generate a strong random string)
# Required in server mode to prevent unauthorized access
HERMES_AUTH_TOKEN=

# CORS origins (comma-separated, for web UI integrations)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Database Configuration
# =============================================================================
# Optional: PostgreSQL for persistent memory across restarts.
# If not set, SQLite is used (good for single-user, local usage).

# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://hermes:hermes_dev@localhost:5432/hermes_squad

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=hermes_dev

# Redis URL (optional: for caching and pub/sub)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Agent Configuration
# =============================================================================

# Default agent to use when starting sessions
# Options: claude, kiro, codex, gemini, aider, hermes
DEFAULT_AGENT=claude

# Claude Code model selection
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI model for Codex CLI
OPENAI_MODEL=gpt-4o

# Gemini model
GEMINI_MODEL=gemini-2.5-pro

# Maximum concurrent agent sessions
MAX_SESSIONS=5

# Enable git worktrees for session isolation
ENABLE_WORKTREES=true

# Auto-start these agents on launch (comma-separated)
# Example: AUTO_START_AGENTS=claude,kiro
AUTO_START_AGENTS=

# =============================================================================
# Git Configuration
# =============================================================================

# Git branch prefix for agent worktrees
GIT_BRANCH_PREFIX=hermes/

# Auto-commit agent changes (true/false)
GIT_AUTO_COMMIT=false

# Git author for agent commits
GIT_AUTHOR_NAME=Hermes Squad
GIT_AUTHOR_EMAIL=hermes@localhost

# =============================================================================
# MCP (Model Context Protocol) Configuration
# =============================================================================

# MCP transport mode: "stdio" | "http" | "sse"
MCP_TRANSPORT=stdio

# MCP HTTP port (only used when MCP_TRANSPORT=http)
MCP_PORT=3849

# Enable MCP server (exposes Hermes capabilities to external AI tools)
MCP_ENABLED=true

# =============================================================================
# Docker Configuration (for docker-compose)
# =============================================================================

# Path to your project workspace (mounted into container)
WORKSPACE_PATH=.

# Exposed ports (change if defaults conflict)
POSTGRES_PORT=5432
REDIS_PORT=6379

# =============================================================================
# Development / Debug
# =============================================================================

# Enable debug mode (verbose logging, dev tools, source maps)
DEBUG=false

# Enable hot-reload for skills during development
HOT_RELOAD_SKILLS=true

# Electron DevTools (only in electron mode)
ELECTRON_DEV_TOOLS=false

# Disable telemetry/analytics
DISABLE_TELEMETRY=true

# Skip update checks
SKIP_UPDATE_CHECK=false
