{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@acp/*": ["./src/acp/*"],
      "@mcp/*": ["./src/mcp/*"],
      "@skills/*": ["./src/skills/*"],
      "@memory/*": ["./src/memory/*"],
      "@gateway/*": ["./src/gateway/*"],
      "@cron/*": ["./src/cron/*"],
      "@ui/*": ["./src/ui/*"],
      "@tui/*": ["./src/tui/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
