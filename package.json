{
  "name": "hermes-squad",
  "version": "0.1.0",
  "description": "Multi-agent terminal manager with self-improving AI — merging Claude Squad + Hermes Desktop",
  "author": "Hermes Squad Contributors",
  "license": "MIT",
  "main": "dist/main.js",
  "bin": {
    "hermes-squad": "./dist/cli.js",
    "hs": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "dev:tui": "tsx src/tui/index.ts",
    "build": "tsc && electron-builder",
    "build:tui": "tsc --project tsconfig.tui.json",
    "start": "electron dist/main.js",
    "start:tui": "node dist/tui/index.js",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "mcp:serve": "tsx src/mcp/server.ts",
    "acp:serve": "tsx src/acp/server.ts",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron": "^28.1.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",

    "node-pty": "^1.0.0",
    "tmux-control": "^0.2.0",

    "blessed": "^0.1.81",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.2.0",

    "jsonrpc-lite": "^2.2.0",
    "vscode-jsonrpc": "^8.2.0",
    "ws": "^8.16.0",
    "express": "^4.18.2",

    "@modelcontextprotocol/sdk": "^0.5.0",

    "better-sqlite3": "^9.4.3",
    "keyv": "^4.5.4",

    "simple-git": "^3.22.0",

    "croner": "^8.0.0",

    "zod": "^3.22.4",
    "nanoid": "^5.0.4",
    "eventemitter3": "^5.0.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "chalk": "^5.3.0",
    "conf": "^12.0.0",
    "glob": "^10.3.10",
    "chokidar": "^3.5.3",

    "slack-bolt": "^3.17.1",
    "discord.js": "^14.14.1",
    "telegraf": "^4.15.3",

    "openai": "^4.24.7",
    "@anthropic-ai/sdk": "^0.12.0",
    "@google/generative-ai": "^0.2.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/node": "^20.10.8",
    "@types/blessed": "^0.1.25",
    "@types/better-sqlite3": "^7.6.8",
    "@types/ws": "^8.5.10",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.47",
    "electron-builder": "^24.9.1",
    "vitest": "^1.2.0",
    "@playwright/test": "^1.41.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.4"
  },
  "build": {
    "appId": "com.hermes-squad.app",
    "productName": "Hermes Squad",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
