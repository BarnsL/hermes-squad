# ═══════════════════════════════════════════════════════════
# Hermes Squad .gitignore
# ═══════════════════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs

# ─── Build Output ─────────────────────────────────────────
dist/
build/
out/
lib/
*.tsbuildinfo
*.js.map
*.d.ts
!src/**/*.d.ts

# ─── Go Build ─────────────────────────────────────────────
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# ─── Package Manager ─────────────────────────────────────
package-lock.json
yarn.lock
# Keep pnpm-lock.yaml (our preferred lockfile)

# ─── Testing ─────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
.vitest/

# ─── Electron ─────────────────────────────────────────────
release/
*.dmg
*.snap
*.AppImage
*.deb
*.rpm
*.msi
*.nupkg

# ─── Environment & Secrets ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.agent
*.pem
*.key
*.cert

# ─── IDE & Editors ────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.template
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ─── OS Files ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Runtime ──────────────────────────────────────────────
*.pid
*.pid.lock
*.seed

# ─── Hermes Squad Runtime ─────────────────────────────────
.hermes-squad/worktrees/
.hermes-squad/skills.db
.hermes-squad/logs/
.hermes-squad/cache/
.hermes-squad/sessions/

# ─── Intelligence Layer ───────────────────────────────────
*.db-journal
*.db-wal
*.db-shm
skills-backup-*.db

# ─── Temporary Files ─────────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig

# ─── Documentation Build ─────────────────────────────────
docs/_build/
docs/.vitepress/dist/
docs/.vitepress/cache/
site/

# ─── Debug ────────────────────────────────────────────────
.node-inspect/
.debug/

# ─── Turborepo ────────────────────────────────────────────
.turbo/

# ─── Nx ───────────────────────────────────────────────────
.nx/

# ─── Misc ─────────────────────────────────────────────────
*.tgz
.eslintcache
.prettiercache
.cache/
